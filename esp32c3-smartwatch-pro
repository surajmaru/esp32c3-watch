void setupWebServer(){
  server.on("/",[](){ server.send_P(200,"text/html",WEB_UI); });

  server.on("/status",[](){
    StaticJsonDocument<256> d;
    d["wifi"]=(WiFi.status()==WL_CONNECTED);
    d["ble"]=watch.isConnected();
    d["phoneBattery"]=phoneBattery;
    d["uptime"]=millis()/1000;
    d["freeRam"]=ESP.getFreeHeap();
    d["screen"]=currentScreen;
    d["ip"]=WiFi.localIP().toString();
    String out; serializeJson(d,out); server.send(200,"application/json",out);
  });

  server.on("/screen",[](){
    if(server.hasArg("id")) goToScreen(server.arg("id").toInt());
    StaticJsonDocument<64> d; d["screen"]=currentScreen;
    String out; serializeJson(d,out); server.send(200,"application/json",out);
  });

  server.on("/settime",[](){
    if(server.hasArg("h")) hours=server.arg("h").toInt();
    if(server.hasArg("m")) minutes=server.arg("m").toInt();
    seconds=0; lastTick=millis();
    server.send(200,"application/json","{\"ok\":true}");
  });

  server.on("/syncntp",[](){
    syncNTP();
    server.send(200,"application/json","{\"ok\":true}");
  });

  server.on("/weather",[](){
    fetchWeather();
    StaticJsonDocument<512> d;
    d["temp"]=(int)wx.tempC; d["humidity"]=wx.humidity; d["uv"]=wx.uvIndex; d["condition"]=wx.condition;
    JsonArray fa=d.createNestedArray("forecast"); JsonArray fc=d.createNestedArray("fcond");
    for(int i=0;i<3;i++){fa.add((int)wx.forecast[i]);fc.add(wx.fCond[i]);}
    String out; serializeJson(d,out); server.send(200,"application/json",out);
  });

  server.on("/face",[](){
    if(server.hasArg("id")){
      faceStyle=server.arg("id").toInt();
      facePhase=0; faceSubStep=0; faceTimer=millis();
      eyeState=EYE_OPEN; pupilOffset={0,0};
      goToScreen(1);
    }
    server.send(200,"application/json","{\"ok\":true}");
  });

  server.on("/sleep",[](){
    server.send(200,"application/json","{\"ok\":true}");
  });

  server.on("/forcesleep",[](){
    display.clearDisplay(); display.display();
    display.oled_command(0xAE); displayOn=false;
    server.send(200,"application/json","{\"ok\":true}");
  });

  server.begin();
  Serial.println("Web: http://"+WiFi.localIP().toString());
}

