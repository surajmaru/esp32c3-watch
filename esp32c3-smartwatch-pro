// ════════════════════════════════════════════════════
// DISPLAY SLEEP
// ════════════════════════════════════════════════════
void wakeDisplay(){
  if(!displayOn){ display.oled_command(0xAF); displayOn=true; }
  lastActivityMs=millis();
}
void checkSleep(){
  if(displayOn&&millis()-lastActivityMs>=SLEEP_TIMEOUT){
    display.clearDisplay(); display.display();
    display.oled_command(0xAE); displayOn=false;
  }
}

// ════════════════════════════════════════════════════
// SCREEN TRANSITION
// ════════════════════════════════════════════════════
void goToScreen(int s){
  if(s==currentScreen) return;
  prevScreen=currentScreen; currentScreen=s;
  transitioning=true; transStart=millis();
  wakeDisplay();
  if(s==1){ eyeState=EYE_OPEN; pupilOffset={0,0}; facePhase=0; faceSubStep=0; faceTimer=millis(); }
  if(s==3) notifViewIdx=max(0,notifCount-1);
}

// ════════════════════════════════════════════════════
// NTP
// ════════════════════════════════════════════════════
void syncNTP(){
  if(WiFi.status()!=WL_CONNECTED) return;
  configTime(GMT_OFFSET_SEC,DST_OFFSET_SEC,NTP_SERVER);
  struct tm t;
  if(getLocalTime(&t)){
    hours=t.tm_hour; minutes=t.tm_min; seconds=t.tm_sec;
    lastTick=millis(); lastNtpSync=millis();
    Serial.println("NTP: "+twoDigit(hours)+":"+twoDigit(minutes));
  }
}

// ════════════════════════════════════════════════════
// WEATHER
// ════════════════════════════════════════════════════
void fetchWeather(){
  if(WiFi.status()!=WL_CONNECTED) return;
  HTTPClient http;
  String url="http://api.openweathermap.org/data/2.5/weather?id=";
  url+=OWM_CITY_ID; url+="&appid="; url+=OWM_API_KEY; url+="&units=metric";
  http.begin(url);
  if(http.GET()==200){
    StaticJsonDocument<1024> d;
    if(!deserializeJson(d,http.getString())){
      wx.tempC=d["main"]["temp"].as<float>();
      wx.humidity=d["main"]["humidity"].as<int>();
      wx.condition=d["weather"][0]["description"].as<String>();
      wx.icon=d["weather"][0]["icon"].as<String>();
      if(wx.condition.length()) wx.condition[0]=toupper(wx.condition[0]);
    }
  }
  http.end();
  String urlUV="http://api.openweathermap.org/data/2.5/uvi?appid=";
  urlUV+=OWM_API_KEY; urlUV+="&lat=19.08&lon=72.88";
  http.begin(urlUV);
  if(http.GET()==200){ StaticJsonDocument<128> d2; if(!deserializeJson(d2,http.getString())) wx.uvIndex=(int)d2["value"].as<float>(); }
  http.end();
  String urlF="http://api.openweathermap.org/data/2.5/forecast?id=";
  urlF+=String(OWM_CITY_ID); urlF+="&appid="; urlF+=String(OWM_API_KEY); urlF+="&units=metric&cnt=24";
  http.begin(urlF);
  if(http.GET()==200){
    DynamicJsonDocument d3(4096);
    if(!deserializeJson(d3,http.getString()))
      for(int i=0;i<3;i++){ int idx=(i+1)*8; wx.forecast[i]=d3["list"][idx]["main"]["temp_max"].as<float>(); wx.fCond[i]=d3["list"][idx]["weather"][0]["main"].as<String>(); }
  }
  http.end();
  wx.lastUpdate=millis();
  Serial.println("Weather: "+String(wx.tempC)+"C "+wx.condition);
}

// ════════════════════════════════════════════════════
// BLE CALLBACKS
// ════════════════════════════════════════════════════
void onNotification(Notification notif){
  if(notifCount<MAX_NOTIFS){ notifQueue[notifCount++]={notif.app,notif.title,notif.message,millis()}; }
  else{ for(int i=0;i<MAX_NOTIFS-1;i++) notifQueue[i]=notifQueue[i+1]; notifQueue[MAX_NOTIFS-1]={notif.app,notif.title,notif.message,millis()}; }
  hasNewNotif=true; notifViewIdx=notifCount-1;
  wakeDisplay(); goToScreen(3);
}
void onNavigation(Navigation navD){
  nav.instruction=navD.directions; nav.distance=navD.distance;
  String ic=String((char*)navD.icon); ic.toLowerCase();
  if(ic.indexOf("left")>=0) nav.arrow="<";
  else if(ic.indexOf("right")>=0) nav.arrow=">";
  else if(ic.indexOf("uturn")>=0) nav.arrow="U";
  else if(ic.indexOf("arrive")>=0) nav.arrow="*";
  else nav.arrow="^";
  nav.active=true; wakeDisplay(); goToScreen(4);
}
void onConnection(bool connected){
  phoneConnected=connected;
  if(!connected) phoneBattery=-1;
  Serial.println(connected?"BLE: connected":"BLE: disconnected");
}

