void showSetScreen(){
  display.setTextSize(1);drawCentered("SET TIME",2);
  String hr=(setStep==0&&!blinkOn)?"  ":twoDigit(to12hr(hours));
  String mn=(setStep==1&&!blinkOn)?"  ":twoDigit(minutes);
  display.setTextSize(2);drawCentered(hr+":"+mn+":"+twoDigit(seconds),16);
  if(setStep==0)display.drawLine(16,38,39,38,SH110X_WHITE);else display.drawLine(52,38,75,38,SH110X_WHITE);
  display.setTextSize(1);drawCentered(getAmPm(hours),44);drawCentered("Tap=+1  Hold btn=Next",55);
}
