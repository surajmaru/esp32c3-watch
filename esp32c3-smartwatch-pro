// CLOCK SCREEN
// ════════════════════════════════════════════════════
void showClock(){
  display.setTextSize(1);
  display.setCursor(2,2); display.print("LOGICSURU");
  display.setCursor(86,2);
  if(watch.isConnected()){display.print("BLE");if(phoneBattery>=0){display.print(" ");display.print(phoneBattery);display.print("%");}}
  else display.print("BLE...");
  if(hasNewNotif) display.fillCircle(124,4,3,SH110X_WHITE);
  String ts=twoDigit(to12hr(hours))+":"+twoDigit(minutes)+":"+twoDigit(seconds);
  display.setTextSize(2); drawCentered(ts,18);
  display.setTextSize(1); drawCentered(getAmPm(hours),38);
  if(wx.tempC!=0){
    display.drawLine(0,47,127,47,SH110X_WHITE);
    display.setCursor(2,51); display.print(String((int)wx.tempC)+"C");
    display.setCursor(30,51); String c=wx.condition; if(c.length()>12)c=c.substring(0,12); display.print(c);
    display.setCursor(100,51); display.print("UV"+String(wx.uvIndex));
  }
  if(WiFi.status()==WL_CONNECTED){display.drawPixel(125,57,SH110X_WHITE);display.drawPixel(126,57,SH110X_WHITE);}
}

// ════════════════════════════════════════════════════
// FACE SCREEN  (16 styles)
// ════════════════════════════════════════════════════
#define EYE_W       22
#define EYE_H       20
#define EYE_SQH      8
#define EYE_BLH      3
#define PUPIL_R      5
#define EL          38
#define ER          90
#define ECY         26

void drawEye(int cx,int cy,int eh,Vec2 p){
  int hw=EYE_W/2,hh=eh/2;
  display.fillRoundRect(cx-hw,cy-hh,EYE_W,eh,5,SH110X_WHITE);
  if(eh>6){display.fillRoundRect(cx-hw+2,cy-hh+2,EYE_W-4,eh-4,4,SH110X_BLACK);
    display.fillCircle(cx+p.x,cy+p.y,PUPIL_R,SH110X_WHITE);display.fillCircle(cx+p.x+2,cy+p.y-2,1,SH110X_BLACK);}
}
void dSmile(int cx,int cy,int r){for(int a=20;a<=160;a+=5){float rd=a*3.14159f/180.f;int px=cx+(int)(r*cos(rd)),py=cy+(int)(r*sin(rd));display.drawPixel(px,py,SH110X_WHITE);display.drawPixel(px,py+1,SH110X_WHITE);}}
void dFrown(int cx,int cy,int r){for(int a=200;a<=340;a+=5){float rd=a*3.14159f/180.f;display.drawPixel(cx+(int)(r*cos(rd)),cy+(int)(r*sin(rd)),SH110X_WHITE);}}

void showFaceScreen(){
  int eh=(eyeState==EYE_BLINK)?EYE_BLH:(eyeState==EYE_SQUINT)?EYE_SQH:EYE_H;
  Vec2 po=(eyeState==EYE_OPEN)?pupilOffset:(Vec2){0,0};

  switch(faceStyle){
    case 0: drawEye(EL,ECY,eh,po);drawEye(ER,ECY,eh,po);dSmile(64,44,10);break;
    case 1: drawEye(EL,ECY,EYE_SQH,{0,0});drawEye(ER,ECY,EYE_SQH,{0,0});display.setTextSize(1);display.setCursor(100,4);display.print("z");display.setCursor(107,0);display.print("Z");dSmile(64,44,8);break;
    case 2: drawEye(EL,ECY,eh,po);drawEye(ER,ECY,eh,po);display.drawLine(27,14,49,20,SH110X_WHITE);display.drawLine(79,20,101,14,SH110X_WHITE);dFrown(64,50,9);break;
    case 3: display.fillRoundRect(26,18,26,14,3,SH110X_WHITE);display.fillRoundRect(76,18,26,14,3,SH110X_WHITE);display.fillRoundRect(28,19,22,11,2,SH110X_BLACK);display.fillRoundRect(78,19,22,11,2,SH110X_BLACK);display.drawLine(52,23,76,23,SH110X_WHITE);dSmile(64,46,10);break;
    case 4: drawEye(EL,ECY-2,EYE_H+4,{0,0});drawEye(ER,ECY-2,EYE_H+4,{0,0});display.drawCircle(64,50,8,SH110X_WHITE);break;
    case 5: drawEye(ER,ECY,eh,po);display.drawLine(28,ECY,48,ECY,SH110X_WHITE);dSmile(64,46,10);break;
    case 6: for(int d=6;d<=14;d++){display.drawPixel(EL-d+6,ECY-d+6,SH110X_WHITE);display.drawPixel(EL+d-6,ECY-d+6,SH110X_WHITE);display.drawPixel(ER-d+6,ECY-d+6,SH110X_WHITE);display.drawPixel(ER+d-6,ECY-d+6,SH110X_WHITE);}for(int x=42;x<=86;x+=4)display.drawPixel(x,50+((x/4)%2)*3,SH110X_WHITE);break;
    case 7: display.drawRect(27,16,24,16,SH110X_WHITE);display.drawRect(77,16,24,16,SH110X_WHITE);for(int i=0;i<3;i++){display.fillRect(30+i*7,21,4,4,SH110X_WHITE);display.fillRect(80+i*7,21,4,4,SH110X_WHITE);}display.drawRect(44,42,40,12,SH110X_WHITE);for(int j=1;j<4;j++)display.drawLine(44+j*10,42,44+j*10,54,SH110X_WHITE);break;
    case 8: drawEye(EL,ECY,eh,po);drawEye(ER,ECY,eh,po);display.fillTriangle(20,4,30,18,40,4,SH110X_WHITE);display.fillTriangle(88,4,98,18,108,4,SH110X_WHITE);display.fillTriangle(60,40,64,45,68,40,SH110X_WHITE);display.drawLine(28,44,54,47,SH110X_WHITE);display.drawLine(28,48,54,48,SH110X_WHITE);display.drawLine(74,47,100,44,SH110X_WHITE);display.drawLine(74,48,100,48,SH110X_WHITE);dSmile(64,50,8);break;
    case 9: display.drawCircle(EL,ECY,11,SH110X_WHITE);display.drawCircle(ER,ECY,11,SH110X_WHITE);display.fillCircle(EL+po.x,ECY+po.y,5,SH110X_WHITE);display.fillCircle(ER+po.x,ECY+po.y,5,SH110X_WHITE);dSmile(64,46,8);break;
    case 10: drawEye(EL,ECY,eh,po);drawEye(ER,ECY,eh,po);display.fillCircle(60,49,4,SH110X_WHITE);display.fillCircle(68,49,4,SH110X_WHITE);display.fillTriangle(54,51,74,51,64,60,SH110X_WHITE);break;
    case 11: for(int a=180;a<=360;a+=8){float r=a*3.14159f/180.f;display.drawPixel(EL+(int)(10*cos(r)),ECY+(int)(7*sin(r)),SH110X_WHITE);display.drawPixel(ER+(int)(10*cos(r)),ECY+(int)(7*sin(r)),SH110X_WHITE);}display.drawLine(48,50,54,56,SH110X_WHITE);display.drawLine(54,56,60,50,SH110X_WHITE);display.drawLine(60,50,68,56,SH110X_WHITE);display.drawLine(68,56,74,50,SH110X_WHITE);break;
    case 12: drawEye(EL,ECY,eh,po);drawEye(ER,ECY,eh,po);dSmile(64,44,10);for(int y=10;y<55;y+=7)display.drawLine(0,y,128,y+2,SH110X_WHITE);break;
    case 13: drawEye(EL,ECY,eh,{po.x+2,po.y});drawEye(ER,ECY,eh,{po.x-2,po.y});display.drawLine(40,44,88,44,SH110X_WHITE);display.drawLine(40,53,88,53,SH110X_WHITE);display.drawLine(40,44,40,53,SH110X_WHITE);display.drawLine(88,44,88,53,SH110X_WHITE);for(int t=0;t<5;t++)display.drawLine(48+t*9,44,48+t*9,53,SH110X_WHITE);break;
    case 14: drawEye(EL,ECY,eh,po);drawEye(ER,ECY,eh,po);display.drawLine(50,50,64,46,SH110X_WHITE);display.drawLine(64,46,78,52,SH110X_WHITE);break;
    case 15: drawEye(EL,ECY-2,EYE_H+4,{0,0});drawEye(ER,ECY-2,EYE_H+4,{0,0});display.drawLine(26,10,48,15,SH110X_WHITE);display.drawLine(80,15,102,10,SH110X_WHITE);display.drawCircle(64,51,8,SH110X_WHITE);break;
    default: drawEye(EL,ECY,eh,po);drawEye(ER,ECY,eh,po);dSmile(64,44,10);
  }

  // rosy cheeks always
  for(int d=-4;d<=4;d+=2){display.drawPixel(EL+d,ECY+16+(abs(d)%2),SH110X_WHITE);display.drawPixel(ER+d,ECY+16+(abs(d)%2),SH110X_WHITE);}
  display.setTextSize(1);
  // drawCentered(twoDigit(to12hr(hours))+":"+twoDigit(minutes)+" "+getAmPm(hours),56);
}

