void updateBlink(){
  if(millis()-lastBlink>=500){blinkOn=!blinkOn;lastBlink=millis();}
}

// ════════════════════════════════════════════════════
// FACE ANIMATION
// ════════════════════════════════════════════════════
void updateFaceAnimation(){
  unsigned long now=millis();
  switch(facePhase){
    case 0: eyeState=EYE_OPEN;pupilOffset={0,0};if(now-faceTimer>800){facePhase=1;faceSubStep=0;faceTimer=now;}break;
    case 1: if(faceSubStep==0){eyeState=EYE_BLINK;if(now-faceTimer>100){faceSubStep=1;faceTimer=now;}}
            else{eyeState=EYE_OPEN;if(now-faceTimer>120){facePhase=2;faceTimer=now;}}break;
    case 2: eyeState=EYE_OPEN;pupilOffset={-4,0};if(now-faceTimer>450){facePhase=3;faceTimer=now;}break;
    case 3: pupilOffset={4,0};if(now-faceTimer>450){facePhase=4;faceTimer=now;}break;
    case 4: pupilOffset={0,0};if(now-faceTimer>250){facePhase=5;faceTimer=now;}break;
    case 5: pupilOffset={0,-3};if(now-faceTimer>400){facePhase=6;faceTimer=now;}break;
    case 6: pupilOffset={0,3};if(now-faceTimer>400){facePhase=7;faceTimer=now;}break;
    case 7: pupilOffset={0,0};if(now-faceTimer>250){facePhase=8;faceSubStep=0;faceTimer=now;}break;
    case 8:{const Vec2 rp[]={{4,0},{3,3},{0,4},{-3,3},{-4,0},{-3,-3},{0,-4},{3,-3}};
      pupilOffset=rp[faceSubStep%8];if(now-faceTimer>140){faceSubStep++;faceTimer=now;
      if(faceSubStep>=8){facePhase=9;faceSubStep=0;pupilOffset={0,0};faceTimer=now;}}break;}
    case 9: if(faceSubStep==0){eyeState=EYE_SQUINT;if(now-faceTimer>350){faceSubStep=1;faceTimer=now;}}
            else{eyeState=EYE_OPEN;if(now-faceTimer>300){facePhase=10;faceSubStep=0;faceTimer=now;}}break;
    case 10: eyeState=(faceSubStep%2==0)?EYE_BLINK:EYE_OPEN;
      if(now-faceTimer>80){faceSubStep++;faceTimer=now;
      if(faceSubStep>=4){facePhase=0;faceSubStep=0;faceTimer=now;}}break;
    default: facePhase=0;break;
  }
}

// ════════════════════════════════════════════════════
// DRAW ROUTER
// ════════════════════════════════════════════════════
void drawScreen(){
  display.clearDisplay();

  if(transitioning){
    int el = millis() - transStart;

    if(el >= TRANS_MS){
      transitioning = false;
      renderScreen(currentScreen);
    } 
    else if(el < TRANS_MS / 2){
      // first half → show previous screen
      renderScreen(prevScreen);
    } 
    else {
      // middle flash (fake fade)
      display.clearDisplay();
    }
  } 
  else {
    renderScreen(setMode ? -1 : currentScreen);
  }

  display.display();
}
void renderScreen(int s){
  if(s==-1)      showSetScreen();
  else if(s==1)  showFaceScreen();
  else if(s==2)  showWeatherScreen();
  else if(s==3)  showNotifScreen();
  else if(s==4)  showNavScreen();
  else           showClock();
}

