// SETUP
// ════════════════════════════════════════════════════
void setup(){
  Serial.begin(115200);
  pinMode(BUTTON_PIN,INPUT_PULLUP);
  pinMode(TOUCH_PIN,INPUT);
  Wire.begin(SDA_PIN,SCL_PIN); delay(100);

  if(!display.begin(0x3C,true)){Serial.println("Display failed!"); while(true);}
  display.setTextColor(SH110X_WHITE);
  display.clearDisplay();
  display.setTextSize(1); drawCentered("LOGICSURU",18); drawCentered("SmartWatch Pro",30); drawCentered("Booting...",44);
  display.display(); delay(1200);

  display.clearDisplay(); drawCentered("Connecting WiFi",22); drawCentered(WIFI_SSID,34); display.display();
  WiFi.begin(WIFI_SSID,WIFI_PASS);
  unsigned long ws=millis();
  while(WiFi.status()!=WL_CONNECTED&&millis()-ws<10000){delay(300);Serial.print(".");}

  if(WiFi.status()==WL_CONNECTED){
    Serial.println("\nWiFi: "+WiFi.localIP().toString());
    display.clearDisplay(); drawCentered("WiFi OK",20); drawCentered(WiFi.localIP().toString(),32); display.display(); delay(1000);
    syncNTP(); fetchWeather(); setupWebServer();
  } else {
    Serial.println("WiFi failed");
    display.clearDisplay(); drawCentered("WiFi Failed",22); drawCentered("Offline Mode",34); display.display(); delay(1000);
  }

  // BLE — register callbacks then start
  watch.setNotificationCallback(onNotification);
  watch.setConnectionCallback(onConnection);
  watch.begin();
  Serial.println("BLE started");

  lastActivityMs=millis(); faceTimer=millis();
  display.clearDisplay(); display.display();
}

// ════════════════════════════════════════════════════
// LOOP
// ════════════════════════════════════════════════════
unsigned long lastBleRestart = 0;
void loop(){
  watch.loop();

  // ── BLE AUTO-RECONNECT ────────────────────────────
  // Detect disconnect edge → immediately restart BLE
  // so phone can find and reconnect without manual re-pair
  bool nowConn = watch.isConnected();

  if (bleWasConnected && !nowConn) {
    if (millis() - lastBleRestart > 5000) { // 5 sec cooldown
      Serial.println("BLE dropped — restarting advertising...");
      watch.begin();
      lastBleRestart = millis();
    }
  }

  bleWasConnected = nowConn;
  // ─────────────────────────────────────────────────

  server.handleClient();
  if(WiFi.status()==WL_CONNECTED&&millis()-lastNtpSync>=NTP_INTERVAL) syncNTP();
  if(WiFi.status()==WL_CONNECTED&&millis()-wx.lastUpdate>=WEATHER_INTERVAL) fetchWeather();

  if(watch.isConnected()){
    Navigation navD=watch.getNavigation();
    if(navD.active) onNavigation(navD);
    phoneBattery=watch.getPhoneBattery();
  }

  updateTime(); handleTouch(); handleButton(); updateBlink(); checkSleep();

  if(displayOn){
    if(currentScreen==1) updateFaceAnimation();
    drawScreen();
  }
}

// ════════════════════════════════════════════════════
// TIME
// ════════════════════════════════════════════════════
void updateTime(){
  if(!setMode&&millis()-lastTick>=1000){
    lastTick=millis();
    if(++seconds>=60){seconds=0;if(++minutes>=60){minutes=0;if(++hours>=24)hours=0;}}
  }
}

// ════════════════════════════════════════════════════
// TOUCH
// ════════════════════════════════════════════════════
void handleTouch(){
  bool raw=digitalRead(TOUCH_PIN);
  if(raw!=lastRawTouch){touchDebounce=millis();lastRawTouch=raw;}
  if(millis()-touchDebounce<=TOUCH_DEBOUNCE) return;
  bool stable=raw;
  if(lastStableTouch==LOW&&stable==HIGH){touchPressStart=millis();touchLongHandled=false;}
  if(stable==HIGH&&!touchLongHandled&&millis()-touchPressStart>=600){touchLongHandled=true;onTouchLong();}
  if(lastStableTouch==HIGH&&stable==LOW&&!touchLongHandled) onTouchTap();
  lastStableTouch=stable;
}
void onTouchTap(){
  if(!displayOn){wakeDisplay();return;}
  wakeDisplay();
  if(setMode){
    if(setStep==0)hours=(hours+1)%24; else minutes=(minutes+1)%60;
    seconds=0;lastTick=millis();
  } else {
    goToScreen((currentScreen+1)%(nav.active?5:4));
  }
}
void onTouchLong(){
  wakeDisplay();
  if(currentScreen==3&&notifCount>0) notifViewIdx=(notifViewIdx+1)%notifCount;
  else goToScreen(0);
}

// ════════════════════════════════════════════════════
// BUTTON
// ════════════════════════════════════════════════════
void handleButton(){
  bool raw=digitalRead(BUTTON_PIN);
  if(raw!=lastRawReading){lastDebounceTime=millis();lastRawReading=raw;}
  if(millis()-lastDebounceTime<=debounceDelay) return;
  bool stable=raw;
  if(lastButtonState==HIGH&&stable==LOW){pressStart=millis();longPressHandled=false;}
  if(stable==LOW&&!longPressHandled&&millis()-pressStart>=600){handleLongPress();longPressHandled=true;wakeDisplay();}
  if(lastButtonState==LOW&&stable==HIGH&&!longPressHandled) wakeDisplay();
  lastButtonState=stable;
}
void handleLongPress(){
  if(currentScreen==1){goToScreen(0);return;}
  if(!setMode){setMode=true;setStep=0;seconds=0;lastTick=millis();}
  else{if(++setStep>1){setMode=false;setStep=0;}}
}

