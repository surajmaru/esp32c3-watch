void showWeatherScreen(){
  display.setTextSize(1);display.setCursor(2,2);display.print("WEATHER");
  if(wx.lastUpdate>0){
    display.setTextSize(3);display.setCursor(2,12);String ts=String((int)wx.tempC);display.print(ts);
    display.setTextSize(1);display.setCursor(2+ts.length()*18+2,12);display.print("C");
    String c=wx.condition;if(c.length()>16)c=c.substring(0,16);display.setCursor(2,38);display.print(c);
    display.setCursor(2,48);display.print("HUM:"+String(wx.humidity)+"%  UV:"+String(wx.uvIndex));
    display.drawLine(0,57,127,57,SH110X_WHITE);
    // for(int i=0;i<3;i++){display.setCursor(4+i*43,59);display.print("D"+String(i+1)+":"+String((int)wx.forecast[i])+"C");}
  } else {drawCentered("No data",28);drawCentered("Check WiFi",38);}
}

// ════════════════════════════════════════════════════
// NOTIFICATIONS SCREEN
// ════════════════════════════════════════════════════
void showNotifScreen(){
  display.setTextSize(1);display.setCursor(2,2);display.print("NOTIF ");display.print(notifViewIdx+1);display.print("/");display.print(max(1,notifCount));
  if(notifCount==0){drawCentered("No notifications",28);return;}
  WatchNotif &n=notifQueue[notifViewIdx];
  String al=n.app;if(al.length()>10)al=al.substring(0,10);
  display.setCursor(2,14);display.print("["+al+"]");
  String t=n.title;if(t.length()>21)t=t.substring(0,21);
  display.setCursor(2,26);display.print(t);
  String b=n.message;
  if(b.length()>21){display.setCursor(2,38);display.print(b.substring(0,21));display.setCursor(2,48);display.print(b.length()>42?b.substring(21,42)+"..":b.substring(21));}
  else{display.setCursor(2,38);display.print(b);}
  display.setCursor(2,57);display.print("Hold=next");
  hasNewNotif=false;
}

